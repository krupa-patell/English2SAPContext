/* Weak agreement: whenever the role commits with peer B, then B previously
   ran the protocol apparently with that role -- agreement on the two
   identities only, not on any exchanged data. */

/* Requires events: Commit(actor, peer, tuple), Running(actor, peer, tuple),
   Reveal(id), Honest(id). */

lemma weak_agreement:
  "All A B t #i.
     Commit(A, B, t) @ #i
     ==> (Ex t2 #j. Running(B, A, t2) @ #j)
       | (Ex X #r. Reveal(X) @ #r & Honest(X) @ #i)"
